{
        "manifest_version": 2,
        "name": "AutoFill",
        "icons": {
                "300": "icon.png"
        },
        "version": "0.1",
        "permissions": [
                "contextMenus",
                "tabs",
                "http://*/",
                "https://*/",
                "storage"
        ],
        "content_security_policy": "script-src 'self' https://ajax.googleapis.com; object-src 'self'",
        "browser_action": {
                "default_icon": {
                        "16": "icon.png"
                },
                "default_title": "Sort by memory used",
                "default_popup": "popup.html"
        },
        "content_scripts": [
                {
                        "matches": [
                                "<all_urls>"
                        ],
                        "js": [
                                "content.js"
                        ]
                }
        ],
        "background": {
                "scripts": [
                        "background.js"
                ]
        }
}